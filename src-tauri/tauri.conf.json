{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "HyperDesk",
  "version": "1.1.7",
  "identifier": "FAAFE2B2.HyperDesk",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "HyperDesk",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": false,
        "visible": true,
        "backgroundColor": "#0F1015",
        "theme": "Dark"
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'wasm-unsafe-eval'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: https://asset.localhost data:; font-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost"
    },
    "trayIcon": {
      "id": "tray",
      "iconPath": "icons/32x32.png"
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEI3OTQxQjcwQzdGREIzMEUKUldRT3MvM0hjQnVVdDRlYUFlUWJJNTNHdHEvckZoMW81aGRHdDBINnY4eG9WZitGTy9hb1NCRDYK",
      "endpoints": [
        "https://github.com/qetqet910/HyperDesk/releases/latest/download/latest.json"
      ]
    }
  }
}